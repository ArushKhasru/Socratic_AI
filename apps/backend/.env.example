# MongoDB connection string
# Get a free M0 cluster from https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/socratic-ai?retryWrites=true&w=majority

# JWT secret - use any long random string
JWT_SECRET=your_jwt_secret_here

# URL of your deployed web app (used for CORS)
# e.g. https://your-web-app.vercel.app
FRONTEND_URL=http://localhost:3001

# URL of your deployed Python tutor service
# e.g. https://your-python-service.vercel.app
PYTHON_SERVICE_URL=http://localhost:8000

# Port (Vercel sets this automatically; only needed for local dev)
PORT=5000
